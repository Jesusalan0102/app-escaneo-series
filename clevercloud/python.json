{
    "deploy": {
        "static": false
    },
    "run": {
        "module": "streamlit",
        "args": [
            "run",
            "series.py",
            "--server.port",
            "9000",
            "--server.address",
            "0.0.0.0",
            "--server.headless",
            "true"
        ]
    },
    "python": {
        "version": "3.13"
    },
    "environment": {
        "STREAMLIT_CLIENT_TOOLBAR_MODE": "minimal",
        "PYTHONPATH": "."
    }
}
